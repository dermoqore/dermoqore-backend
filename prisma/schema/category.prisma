model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique

  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")

  banners   Banner[]
  products  Product[]

  blogs Blog[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([parentId])
}