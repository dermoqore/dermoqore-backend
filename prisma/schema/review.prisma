enum ReviewStatus {
  PENDING
  APPROVED
  INACTIVE
}

model Review {
  id          String       @id @default(cuid())
  name        String
  description String
  rating      Int          @default(5)
  image       String
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
