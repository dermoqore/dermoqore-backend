generator client {
  provider = "prisma-client"
  output   = "../../src/@generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogs     Blog[]
  addresses Address[]
  orders    Order[]
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}





